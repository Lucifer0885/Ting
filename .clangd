# compile_commands.json in the project root is picked up automatically.
# These flags fix MSVC commands (cl.exe -std:c++latest) for clangd's Clang parser.
CompileFlags:
  CompilationDatabase: .
  Compiler: clang++
  Add:
    - -std=c++23
    - -fms-compatibility
    - -fms-extensions
  Remove:
    - -std:c++latest

---
# Headers are not listed in compile_commands.json; give them an explicit C++23 parse.
If:
  PathMatch: [.*\.h, .*\.hpp]
CompileFlags:
  Add:
    - -std=c++23
    - -xc++-header
    - -fms-compatibility
    - -fms-extensions
